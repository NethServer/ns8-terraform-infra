{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "terraform"
  ],
  "packageRules": [
    {
      "description": "Automerge patch-level dependency updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    }
  ]
}
